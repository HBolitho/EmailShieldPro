<Page
    x:Class="EmailShield_Pro.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EmailShield_Pro.Pages">
    <Grid Background="#0f172a" Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="EmailShield Pro" FontSize="28" Foreground="White" VerticalAlignment="Center"/>
            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Settings" Click="Settings_Click" Height="36"/>
                    <Button Content="Roadmap" Click="Roadmap_Click" Height="36"/>
                    <Button Content="History" Click="History_Click" Height="36"/>
                    <Button Content="Safe List" Click="SafeList_Click" Height="36"/>
                    <Button Content="Accounts" Click="Accounts_Click" Height="36"/>
                    <Button Content="Add Account" Click="AddAccount_Click" Height="36"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="1"
                   Text="Status: Ready" FontSize="16"
                   Foreground="#94a3b8" Margin="0,0,0,8"/>

        <!-- Scan Button -->
        <Button x:Name="ScanBtn" Grid.Row="2"
                Content="Run Full Inbox Scan"
                Click="Scan_Click"
                Width="220" Height="44" Margin="0,0,0,12"/>

        <!-- Progress indicator -->
        <Border x:Name="ScanProgress" Grid.Row="3"
                Height="4" CornerRadius="2"
                Background="#1e293b"
                Visibility="Collapsed"
                Margin="0,0,0,12">
            <Border x:Name="ScanProgressInner"
                    HorizontalAlignment="Left"
                    Width="60" Height="4"
                    CornerRadius="2"
                    Background="#3b82f6"/>
        </Border>

        <!-- Threat Counters -->
        <Grid Grid.Row="4" ColumnSpacing="12" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Background="#dc2626" Padding="12" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="High Risk" Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="HighCount" Text="0" FontSize="24" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#f59e0b" Padding="12" CornerRadius="10" Grid.Column="1">
                <StackPanel>
                    <TextBlock Text="Medium Risk" Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="MediumCount" Text="0" FontSize="24" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#3b82f6" Padding="12" CornerRadius="10" Grid.Column="2">
                <StackPanel>
                    <TextBlock Text="Low Risk" Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="LowCount" Text="0" FontSize="24" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#16a34a" Padding="12" CornerRadius="10" Grid.Column="3">
                <StackPanel>
                    <TextBlock Text="Safe" Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="SafeCount" Text="0" FontSize="24" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Filter Tabs -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <Button x:Name="FilterAll" Content="All" Click="Filter_Click" Tag="All"/>
            <Button x:Name="FilterHigh" Content="High" Click="Filter_Click" Tag="High"/>
            <Button x:Name="FilterMedium" Content="Medium" Click="Filter_Click" Tag="Medium"/>
            <Button x:Name="FilterLow" Content="Low" Click="Filter_Click" Tag="Low"/>
            <Button x:Name="FilterSafe" Content="Safe" Click="Filter_Click" Tag="Safe"/>
        </StackPanel>

        <!-- Results -->
        <ScrollViewer Grid.Row="6">
            <StackPanel x:Name="ResultsList" Spacing="8"/>
        </ScrollViewer>

        <!-- Coder Tag -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Border Background="#1e293b" CornerRadius="6" Padding="10,4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Background="#3b82f6" CornerRadius="3" Padding="5,2">
                        <TextBlock Text="DEV" Foreground="White" FontSize="10" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="Harry Bolitho" Foreground="#94a3b8" FontSize="11"/>
                    <TextBlock Text="v1.0.0" Foreground="#475569" FontSize="11"/>
                </StackPanel>
            </Border>
        </StackPanel>

    </Grid>
</Page>